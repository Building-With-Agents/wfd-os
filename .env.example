# WFD OS — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# === PostgreSQL ===
# These defaults assume a manually-provisioned local DB. In practice, no such
# DB ships with the repo today — the 34 wfd-os tables catalogued in
# docs/database/wfdos-schema-inventory.md are not defined anywhere in source.
# Canonical CREATE TABLE work is tracked in #22.
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_DATABASE=wfdos
PG_PASSWORD=

# --- Local-dev Postgres (docker-compose.dev.yml, PR #37) ---
# To point services at the dedicated wfd-os Docker container instead of a
# manually-set-up local DB or the JIE talent_finder mirror, uncomment these
# (they override the PG_* above) and run:
#     docker compose -f docker-compose.dev.yml up -d
# Note: until the #22 schema work lands, queries will still fail with
# "relation does not exist" — the container is empty aside from pgvector.
#
# PG_HOST=localhost
# PG_PORT=5434
# PG_USER=wfdos
# PG_PASSWORD=wfdos_local_dev
# PG_DATABASE=wfdos
# DATABASE_URL=postgresql://wfdos:wfdos_local_dev@localhost:5434/wfdos

# --- JIE talent_finder mirror (for JIE-data endpoints only) ---
# Azure Postgres with JIE's dbo.* schema (companies, job_postings, skills,
# etc.). Does NOT contain wfd-os tables. Use only for services that
# specifically read JIE data; see docs/database/wfdos-schema-inventory.md.
#
# PG_HOST=pg-jobintel-cfa-dev.postgres.database.azure.com
# PG_PORT=5432
# PG_USER=cfa_readonly
# PG_PASSWORD=<set in your .env; never commit>
# PG_DATABASE=talent_finder

# === Azure AD / WFD-OS App Registration ===
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_PRIMARY=
AZURE_SUBSCRIPTION_CFAX=

# === Azure OpenAI ===
AZURE_OPENAI_ENDPOINT=
