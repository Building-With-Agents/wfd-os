# WFD OS — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# === PostgreSQL ===
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_DATABASE=wfdos
# PG_PASSWORD is set in scripts/pgconfig.py

# === Azure AD / WFD-OS App Registration ===
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_PRIMARY=
AZURE_SUBSCRIPTION_CFAX=

# === Azure OpenAI ===
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# === Azure Blob Storage ===
BLOB_CONNECTION_STRING=

# === Azure Function (legacy matching endpoint) ===
FUNCTION_APP_URL=

# === Dynamics CRM ===
DYNAMICS_DEV_URL=
DYNAMICS_PRIMARY_URL=

# === Microsoft Graph API (Scoping Agent app registration) ===
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# === SharePoint ===
SHAREPOINT_TENANT_URL=https://computinforall.sharepoint.com
INTERNAL_SITE_ID=
CFA_CLIENT_PORTAL_SITE_ID=
GRANT_SHAREPOINT_SITE_ID=
GRANT_SHAREPOINT_SITE_URL=

# === Teams ===
CFA_TEAM_ID=
SCOPING_NOTIFY_CHANNEL_ID=
SCOPING_WEBHOOK_URL=
TEAMS_LEADERSHIP_TEAM_ID=
TEAMS_WSB_CHANNEL_ID=

# === Waifinder Bot ===
WAIFINDER_APP_ID=
WAIFINDER_APP_PASSWORD=

# === Anthropic (legacy — migrating to Gemini) ===
ANTHROPIC_API_KEY=

# === Email (Microsoft Graph sendMail) ===
EMAIL_SENDER=ritu@computingforall.org
NOTIFY_EMAIL=ritu@computingforall.org

# === Gemini LLM ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === Apollo CRM ===
APOLLO_API_KEY=
