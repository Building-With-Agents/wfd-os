# --- Core ---
APP_ENV=development
DATABASE_URL=sqlite:///./grant_compliance.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/grant_compliance

# --- LLM ---
# Set to "anthropic" for real calls, "mock" for offline/dev
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
LLM_CONFIDENCE_THRESHOLD=0.75

# --- QuickBooks Online ---
# Get these from https://developer.intuit.com/ (create an app)
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:8000/qb/callback
QB_ENVIRONMENT=sandbox  # or "production"

# --- Microsoft Graph (Azure AD / Entra) ---
# Register an app at https://entra.microsoft.com → App registrations
# Add a client secret and the redirect URI below.
# Required delegated permissions: User.Read, offline_access, Chat.Read,
# ChannelMessage.Read.All, Sites.Read.All, Files.Read.All, Mail.Read
MSGRAPH_TENANT_ID=          # use "common" for multi-tenant dev
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_REDIRECT_URI=http://localhost:8000/msgraph/callback

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Auth (placeholder until SSO/OIDC is wired) ---
DEV_USER_EMAIL=you@example.org
DEV_USER_NAME=Dev User
